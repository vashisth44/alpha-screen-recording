{
  "name": "screenrecorder",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "main-electron.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "dist": "npm run build && electron-builder"
  },
  "devDependencies": {
    "vite": "^8.0.4"
  },
  "build": {
    "appId": "com.alpha.screenrecorder",
    "productName": "Alpha Screen Recorder",
    "files": [
      "dist/**/*",
      "main-electron.cjs"
    ],
    "win": {
      "target": "portable"
    }
  }
}
